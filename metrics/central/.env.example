# Copy this file to .env and adjust values for your deployment.
# docker compose automatically loads .env from this directory.

# ---------------------------
# Grafana OAuth - Google
# ---------------------------
# https://grafana.com/docs/grafana/latest/setup-grafana/configure-access/configure-authentication/google/
GF_AUTH_GOOGLE_ENABLED=false
GF_AUTH_GOOGLE_CLIENT_ID=
GF_AUTH_GOOGLE_CLIENT_SECRET=
# Comma-separated domains allowed to sign in, e.g. mddbr.eu,irbbarcelona.org
GF_AUTH_GOOGLE_ALLOWED_DOMAINS=

# ---------------------------
# Grafana OAuth - GitHub
# ---------------------------
# https://grafana.com/docs/grafana/latest/setup-grafana/configure-access/configure-authentication/github/
GF_AUTH_GITHUB_ENABLED=false
GF_AUTH_GITHUB_CLIENT_ID=
GF_AUTH_GITHUB_CLIENT_SECRET=
# Comma-separated organization names, e.g. mddb-org,irbbarcelona
GF_AUTH_GITHUB_ALLOWED_ORGANIZATIONS=

# ---------------------------
# Grafana SMTP
# ---------------------------
# Set GF_SMTP_ENABLED=true and fill in the mail server details to allow alerts and
# notification test emails to be sent from Grafana.
# https://tasrieit.com/blog/where-to-setup-grafana-smtp-settings-complete-guide
GF_SMTP_ENABLED=false
# Example: smtp.example.com:587
GF_SMTP_HOST=
GF_SMTP_USER=
GF_SMTP_PASSWORD=
GF_SMTP_FROM_ADDRESS=
GF_SMTP_FROM_NAME=
